generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth required models ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts      Account[]
  sessions      Session[]

  watchlistItems    WatchlistItem[]
  screenerPresets   ScreenerPreset[]
  screenerDefaults  ScreenerDefaults?
  recentlyViewed    RecentlyViewed[]
  notifications     UserNotification[]
  chatSessions      ChatSession[]
  portfolioItems         PortfolioItem[]
  dashboardLayout        DashboardLayout?
  dividendPortfolios     DividendPortfolio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ─────────────────────────────────────────────

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  ticker  String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model ScreenerPreset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScreenerDefaults {
  id          String @id @default(cuid())
  userId      String @unique
  lastFilters Json
  lastSort    String @default("marketCap")
  lastOrder   String @default("desc")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecentlyViewed {
  id       String   @id @default(cuid())
  userId   String
  ticker   String
  name     String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model UserNotification {
  id        String  @id @default(cuid())
  userId    String
  type      String
  ticker    String
  stockName String
  message   String
  date      String
  read      Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PortfolioItem {
  id       String   @id @default(cuid())
  userId   String
  ticker   String
  market   String   // "KR" | "US"
  name     String
  sectorKr String
  quantity Int
  avgPrice Float
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

// ─── Dividend Portfolio ───────────────────────────────────────

model DividendPortfolio {
  id          String   @id @default(cuid())
  userId      String
  name        String
  totalAmount Int                    // 총 투자금 (만원)
  period      Int      @default(10)  // 투자 기간 (년)
  drip        Boolean  @default(false)
  monthlyAdd          Int      @default(0)   // 월 추가 적립 (만원)
  dividendGrowthRate  Float    @default(3)   // 배당 성장률 가정 (%/년)
  createdAt           DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items DividendPortfolioItem[]

  @@index([userId])
}

model DividendPortfolioItem {
  id          String @id @default(cuid())
  portfolioId String
  ticker      String
  market      String // "KR" | "US"
  weight      Float  // 비중 (0~100)

  portfolio DividendPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker, market])
  @@index([portfolioId])
}

// ─── Dashboard layout ─────────────────────────────────────────

model DashboardLayout {
  id          String   @id @default(cuid())
  userId      String   @unique
  cardOrder   Json     // string[] of card IDs in display order
  hiddenCards Json     @default("[]") // string[] of hidden card IDs
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Chat models ──────────────────────────────────────────────

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String      // 'user' | 'assistant' | 'system'
  content     String      @db.Text
  intent      String?
  blocked     Boolean     @default(false)
  dataSources String?     // JSON: list of data sources used (for audit)
  createdAt   DateTime    @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
